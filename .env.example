# Configuración de Credenciales de TheLook Intelligence
# Copie este archivo como '.env' y complete los valores

# --- Kaggle API (Para descarga de Datasets) ---
KAGGLE_USERNAME="tu_usuario_kaggle"
KAGGLE_KEY="tu_llave_api_kaggle"

# --- Seguridad y Privacidad ---
# Sal para el hashing SHA-256 de los IDs (Seudonimización)
USER_SALT="generar_un_string_aleatorio_aqui"

# --- Inteligencia Artificial (Explicabilidad LLM) ---
# Clave necesaria para las traducciones de SHAP a lenguaje natural
GEMINI_API_KEY="tu_google_gemini_api_key_aqui"
